# Supabase Configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# AI Chat (DashScope API with MiniMax-M2.5)
# Optional: If not set, chat falls back to keyword matching
DASHSCOPE_API_KEY=your-dashscope-api-key-here
DASHSCOPE_MODEL=MiniMax-M2.5
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation
