# Supabase Configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# AI Chat (DashScope Anthropic-compatible API)
# Optional: If not set, chat falls back to keyword matching
DASHSCOPE_API_KEY=your-dashscope-api-key-here
DASHSCOPE_MODEL=MiniMax-M2.5
# DASHSCOPE_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/apps/anthropic

# Email — Resend (for booking confirmation emails with .ics attachments)
# Get a free API key at https://resend.com (3000 emails/month free)
# Without this, .ics download still works but no email is sent
RESEND_API_KEY=re_your_api_key_here
# Must be a verified sender domain in Resend (or use onboarding@resend.dev for testing)
RESEND_FROM_EMAIL=PathPal <noreply@your-domain.com>

# WeChat OAuth
# Required for WeChat sign-in. Get from WeChat Open Platform: https://open.weixin.qq.com
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret
# Callback URL must be registered in WeChat Open Platform
WECHAT_REDIRECT_URI=https://your-domain.com/api/auth/wechat/callback
